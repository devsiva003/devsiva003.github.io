---
import { getCollection, render } from 'astro:content';
import Layout from '#/layouts/Layout.astro';
import SchemaOrg from '#/components/SchemaOrg.astro';
import { SharePost } from '#/components/SharePost';
import { siteConfig } from '#/data/site-config';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postUrl = new URL(
  `/posts/${post.id}`,
  import.meta.env.SITE || siteConfig.url
).toString();
const imageUrl = `${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/open-graph/${post.id}.png`;
---

<Layout
  title={`${post.data.title} | Blog`}
  description={post.data.description}
  image={imageUrl}
  type="article"
  publishedTime={post.data.date}
  customSchema
>
  <SchemaOrg
    slot="head"
    type="article"
    headline={post.data.title}
    description={post.data.description || ''}
    datePublished={post.data.date}
    author={siteConfig.author.name}
    url={postUrl}
    image={imageUrl}
  />
  <article class="py-16 pt-28">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12">
      <header class="max-w-2xl mx-auto mb-16 pb-16 border-b-2 border-border">
        <a
          href="/posts"
          class="inline-block font-mono text-sm uppercase tracking-widest mb-8 border-b-2 border-current hover:bg-accent hover:text-bg px-1"
        >
          ← Back to Blog
        </a>
        <time
          datetime={post.data.date.toISOString()}
          class="block font-mono text-sm tracking-widest text-text-muted uppercase mb-4"
        >
          {
            post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        <div class="flex items-start justify-between gap-4 flex-wrap mb-4">
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl uppercase">
            {post.data.title}
          </h1>
        </div>
        {
                    post.data.description && (
                        <p class="text-lg md:text-xl text-text-muted mb-4">
                            {post.data.description}
                        </p>
                    )
                }
        {
          post.data.tags && post.data.tags.length > 0 && (
            <div class="flex gap-2 flex-wrap">
              {post.data.tags.map((tag) => (
                <a href={`/tags/${tag}`} class="tag hover:bg-primary hover:text-bg transition-colors">
                  {tag}
                </a>
              ))}
            </div>
          )
        }
      </header>

      <div
        class="prose dark:prose-invert prose-p:leading-loose max-w-2xl mx-auto"
      >
        <Content/>
      </div>
      <footer
        class="max-w-2xl mx-auto mt-16 pt-8 border-t-2 border-border flex justify-end"
      >
        <SharePost title={post.data.title} url={postUrl} client:load/>
      </footer>
    </div>
  </article>
</Layout>
