---
import { siteConfig } from '#/data/site-config';

interface PersonSchema {
  type: 'person';
  name: string;
  jobTitle?: string;
  url?: string;
  sameAs?: string[];
}

interface WebSiteSchema {
  type: 'website';
  name: string;
  description: string;
  url: string;
}

interface ArticleSchema {
  type: 'article';
  headline: string;
  description: string;
  datePublished: Date;
  dateModified?: Date;
  author: string;
  url: string;
  image?: string;
}

type Props = PersonSchema | WebSiteSchema | ArticleSchema;

const props = Astro.props;
const siteUrl = import.meta.env.SITE || 'https://example.com';

function generateSchema(props: Props) {
  switch (props.type) {
    case 'person':
      return {
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: props.name,
        jobTitle: props.jobTitle,
        url: props.url || siteUrl,
        sameAs: props.sameAs || [],
      };
    case 'website':
      return {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: props.name,
        description: props.description,
        url: props.url,
      };
    case 'article': {
      const authorId = `${siteUrl}/#author`;
      const publisherId = `${siteUrl}/#organization`;
      const imageUrl = props.image?.startsWith('http')
        ? props.image
        : `${siteUrl}${props.image}`;

      return {
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'Person',
            '@id': authorId,
            name: props.author,
            url: siteUrl,
            sameAs: siteConfig.sameAs || [],
          },
          {
            '@type': 'Organization',
            '@id': publisherId,
            name: siteConfig.name,
            url: siteUrl,
            logo: {
              '@type': 'ImageObject',
              url: `${siteUrl}/favicon.svg`,
            },
          },
          {
            '@type': 'BlogPosting',
            '@id': `${props.url}#article`,
            mainEntityOfPage: {
              '@type': 'WebPage',
              '@id': props.url,
            },
            headline: props.headline,
            description: props.description,
            datePublished: props.datePublished.toISOString(),
            dateModified: (
              props.dateModified || props.datePublished
            ).toISOString(),
            author: { '@id': authorId },
            publisher: { '@id': publisherId },
            image: props.image
              ? {
                  '@type': 'ImageObject',
                  url: imageUrl,
                }
              : undefined,
          },
        ],
      };
    }
  }
}

const schema = generateSchema(props);
---

<script type="application/ld+json" set:html={JSON.stringify(schema)}/>
